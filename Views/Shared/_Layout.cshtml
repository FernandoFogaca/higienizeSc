<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Higienize SC | Higienização de Estofados</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HigienizeMVC.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    <header class="site-header" id="header">
        <a class="logo-box" asp-controller="Home" asp-action="Index">
            <img src="/img/logo.png" alt="Higienize SC" class="logo-img">
        </a>

        <nav class="nav-menu">
            <a href="#home">Home</a>
            <a href="#gallery">Galeria</a>
            <a href="#services">Serviços</a>
            <a href="#about">Sobre</a>
            <a href="#testimonials">Depoimentos</a>
            <a href="#faq">FAQ</a>
            <a href="https://wa.me/5548991101206" class="btn-contact" target="_blank">
                <i class="bi bi-whatsapp"></i>
                Contato
            </a>
        </nav>

        <button class="menu-button" type="button">
            ☰
        </button>
    </header>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - HigienizeMVC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>