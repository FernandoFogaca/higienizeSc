@model List<HigienizeMVC.Models.Testimonial>

<section class="hero">
    <h1 class="hero-title">Higienize SC</h1>
    <p class="hero-text">Higienização de estofados em toda Grande Florianópolis.</p>
    <a href="https://wa.me/5548991101206" target="_blank">
   
        <button class="hero-button">
            Solicitar orçamento
        </button>
    </a>
</section>
<section class="before-after">
    <h2 class="section-title">
        Veja nossos resultados
    </h2>
    <p class="section-subtitle">
        Confira a diferença real após a higienização
    </p>
    <div class="before-after-container">

        <div class="before-after-item">
            <img src="/img/before.png" alt="Antes">
            <img src="/img/after.png" alt="Depois">
            
        </div>

    </div>
</section>
<section class="services">
    <h2 class="section-title">Nossos Serviços</h2>
    <p class="section-subtitle">Soluções completas em higienização de estofados para sua casa</p>
    <div class="services-grid">
        <div class="service-card">
            <h3>Higienização de sofás </h3>
            <p>Limpeza profunda que remove sujeiras invisíveis, ácaros e odores, deixando seu sofá renovado e com
                aparência de novo.</p>
            </div>
            <div class="service-card">
                <h3>Higienização de colchões</h3>
                <p>Higienização completa que elimina bactérias e ácaros, ajudando a melhorar a qualidade do seu sono.</p>
            </div>
            <div class="service-card">
                <h3>Higienização de cadeiras</h3>
                <p>Ideal para o dia a dia, removendo manchas e sujeiras acumuladas sem danificar o tecido.</p>
            </div>
            <div class="service-card">
                <h3>Higienização de poltronas</h3>
                <p>Cuide da sua poltrona preferida com uma limpeza que preserva o tecido e devolve o conforto original.</p>
            </div>
            <div class="service-card">
                <h3>Higienização de tapetes</h3>
                <p>Remoção de poeira, odores e impurezas que ficam acumuladas no dia a dia, deixando o ambiente mais limpo e
                    saudável.</p>
                </div>
                <div class="service-card">
                    <h3>Impermeabilização</h3>
                    <p>Proteção contra líquidos e sujeiras, prolongando a vida útil do seu estofado e facilitando a manutenção.
                    </p>
                </div>
            </div>
        </section>
        <section class="testimonials">
            <h2 class="section-title">O que nossos clientes dizem</h2>
            <p class="section-subtitle">Depoimentos de quem já confiou na Higienize SC</p>
            <div class="testimonials-grid">

                @foreach (var testimonial in Model)
                {
                    <div class="testimonial-card">

                        <h3>@testimonial.Name — @testimonial.City</h3>
                        <div class="testimonial-stars">

                            @for (int i = 0; i < testimonial.Rating; i++)
                            {
                                <span>★</span>
                            }
                        </div>

                        <p>@testimonial.Message</p>

                    </div>
                }

            </div>
        </div>


    



    </div>

















</section>